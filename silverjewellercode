<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LUMIÈRE — Sterling Silver Jewellery</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --silver: #C0C0C0;
    --silver-light: #d8d8d8;
    --silver-dark: #9a9a9a;
    --champagne: #E6C79C;
    --champagne-light: #f0dcc0;
    --ivory: #FAF9F6;
    --ivory-dark: #f0ede6;
    --charcoal: #1E1E1E;
    --charcoal-soft: #2e2e2e;
    --text-muted: #7a7a7a;
    --text-light: #a8a8a8;
    --white: #ffffff;
    --glass: rgba(255,255,255,0.7);
    --shadow-soft: 0 4px 30px rgba(0,0,0,0.06);
    --shadow-med: 0 8px 50px rgba(0,0,0,0.1);
    --shadow-heavy: 0 20px 80px rgba(0,0,0,0.15);
    --radius: 2px;
    --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--ivory);
    color: var(--charcoal);
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR */
  .cursor {
    position: fixed;
    width: 8px; height: 8px;
    background: var(--charcoal);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease, background 0.3s ease;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1px solid var(--charcoal);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: transform 0.12s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
    opacity: 0.4;
  }
  body:hover .cursor-ring { opacity: 0.4; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: var(--ivory); }
  ::-webkit-scrollbar-thumb { background: var(--silver); border-radius: 10px; }

  /* NAVIGATION */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 60px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(250,249,246,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(192,192,192,0.2);
    transition: var(--transition);
  }
  nav.scrolled {
    height: 64px;
    box-shadow: var(--shadow-soft);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    color: var(--charcoal);
    text-decoration: none;
  }
  .nav-logo span {
    color: var(--champagne);
  }

  .nav-links {
    display: flex;
    gap: 42px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--charcoal);
    text-decoration: none;
    font-weight: 400;
    position: relative;
    transition: var(--transition);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--champagne);
    transition: width 0.3s ease;
  }
  .nav-links a:hover::after { width: 100%; }

  .nav-actions {
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .nav-icon {
    width: 20px; height: 20px;
    cursor: pointer;
    color: var(--charcoal);
    transition: var(--transition);
    position: relative;
  }
  .nav-icon:hover { color: var(--champagne); }

  .cart-badge {
    position: absolute;
    top: -6px; right: -6px;
    width: 16px; height: 16px;
    background: var(--champagne);
    border-radius: 50%;
    font-size: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--charcoal);
    font-weight: 500;
  }

  /* FLOATING CART */
  .floating-cart {
    position: fixed;
    bottom: 40px;
    right: 40px;
    z-index: 500;
    width: 56px; height: 56px;
    background: var(--charcoal);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 32px rgba(30,30,30,0.3);
    cursor: pointer;
    transition: var(--transition);
    transform: translateY(0);
  }
  .floating-cart:hover {
    transform: translateY(-3px);
    background: var(--charcoal-soft);
    box-shadow: 0 16px 40px rgba(30,30,30,0.4);
  }
  .floating-cart svg { color: white; width: 22px; height: 22px; }
  .floating-cart .badge {
    position: absolute;
    top: -4px; right: -4px;
    width: 20px; height: 20px;
    background: var(--champagne);
    border-radius: 50%;
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: var(--charcoal);
    border: 2px solid var(--ivory);
  }

  /* HERO SECTION */
  .hero {
    height: 100vh;
    min-height: 700px;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(135deg, #f5f4f0 0%, #ede8df 40%, #e8e2d8 100%);
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(192,192,192,0.12) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(230,199,156,0.1) 0%, transparent 40%),
      radial-gradient(circle at 70% 80%, rgba(192,192,192,0.08) 0%, transparent 40%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .hero-orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(230,199,156,0.2) 0%, transparent 70%);
    top: -100px; right: -100px;
    animation: float1 8s ease-in-out infinite;
  }
  .hero-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(192,192,192,0.15) 0%, transparent 70%);
    bottom: -50px; left: 10%;
    animation: float2 10s ease-in-out infinite;
  }

  @keyframes float1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, 30px) scale(1.05); }
  }
  @keyframes float2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -20px); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 80px;
    max-width: 700px;
    animation: heroReveal 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
  @keyframes heroReveal {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--champagne);
    font-weight: 400;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .hero-eyebrow::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--champagne);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 7vw, 6.5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--charcoal);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .hero-title em {
    font-style: italic;
    color: var(--silver-dark);
  }

  .hero-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 48px;
    font-weight: 300;
    max-width: 440px;
    letter-spacing: 0.04em;
  }

  .hero-ctas {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .btn-primary {
    padding: 16px 44px;
    background: var(--charcoal);
    color: white;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
    display: inline-block;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--champagne);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary:hover { color: var(--charcoal); }
  .btn-primary span { position: relative; z-index: 1; }

  .btn-ghost {
    padding: 16px 0;
    background: transparent;
    color: var(--charcoal);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: var(--transition);
  }
  .btn-ghost::after {
    content: '→';
    transition: transform 0.3s ease;
  }
  .btn-ghost:hover::after { transform: translateX(6px); }
  .btn-ghost:hover { color: var(--champagne); }

  .hero-image-side {
    position: absolute;
    right: 0; top: 0; bottom: 0;
    width: 50%;
    overflow: hidden;
  }
  .hero-image-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-jewellery-visual {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: heroImageReveal 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.3s both;
  }
  @keyframes heroImageReveal {
    from { opacity: 0; transform: translateX(60px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* SVG Jewellery Illustration */
  .jewellery-svg-container {
    position: relative;
    width: 500px;
    height: 600px;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 80px;
    display: flex;
    align-items: center;
    gap: 16px;
    z-index: 2;
  }
  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--silver));
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.5; }
  }
  .scroll-text {
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-light);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* MARQUEE */
  .marquee-bar {
    background: var(--charcoal);
    padding: 18px 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .marquee-track {
    display: inline-flex;
    animation: marquee 25s linear infinite;
  }
  .marquee-item {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--silver);
    padding: 0 48px;
    display: flex;
    align-items: center;
    gap: 48px;
  }
  .marquee-item::after {
    content: '✦';
    color: var(--champagne);
    font-size: 0.5rem;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* SECTION COMMONS */
  section { padding: 120px 80px; }
  .section-header {
    text-align: center;
    margin-bottom: 72px;
  }
  .section-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--champagne);
    font-weight: 400;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }
  .section-eyebrow::before, .section-eyebrow::after {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--champagne);
    opacity: 0.6;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300;
    color: var(--charcoal);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .section-title em {
    font-style: italic;
    color: var(--silver-dark);
  }
  .section-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 16px;
    font-weight: 300;
    letter-spacing: 0.06em;
    line-height: 1.7;
  }

  /* COLLECTIONS */
  .collections {
    background: var(--ivory);
    padding: 120px 80px;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 60px;
  }
  .collection-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border-radius: var(--radius);
  }
  .collection-card:nth-child(1) { grid-row: span 2; }
  .collection-visual {
    width: 100%;
    aspect-ratio: 3/4;
    position: relative;
    overflow: hidden;
    background: var(--ivory-dark);
  }
  .collection-card:nth-child(1) .collection-visual { aspect-ratio: 3/5; }
  .collection-visual svg {
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .collection-card:hover .collection-visual svg { transform: scale(1.06); }
  .collection-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 40px 32px 32px;
    background: linear-gradient(to top, rgba(30,30,30,0.7) 0%, transparent 100%);
    color: white;
    transform: translateY(10px);
    transition: var(--transition);
  }
  .collection-card:hover .collection-info { transform: translateY(0); }
  .collection-label {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--champagne);
    margin-bottom: 8px;
    font-weight: 400;
  }
  .collection-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    line-height: 1.1;
  }
  .collection-count {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    margin-top: 8px;
    letter-spacing: 0.08em;
  }
  .collection-arrow {
    position: absolute;
    top: 24px; right: 24px;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.85rem;
    opacity: 0;
    transform: translate(10px, -10px);
    transition: var(--transition);
  }
  .collection-card:hover .collection-arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* BEST SELLERS */
  .bestsellers {
    background: var(--white);
    padding: 120px 80px;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 60px;
  }
  .product-card {
    position: relative;
    cursor: pointer;
  }
  .product-image-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--ivory-dark);
    border-radius: var(--radius);
    margin-bottom: 20px;
  }
  .product-image-wrap .product-img,
  .product-image-wrap .product-img-hover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.5s ease, transform 0.6s ease;
  }
  .product-image-wrap .product-img-hover {
    opacity: 0;
    transform: scale(1.03);
  }
  .product-card:hover .product-img { opacity: 0; }
  .product-card:hover .product-img-hover { opacity: 1; transform: scale(1); }
  .product-card:hover .product-img { transform: scale(1.03); }

  .product-badge {
    position: absolute;
    top: 16px; left: 16px;
    padding: 5px 12px;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    z-index: 2;
    border-radius: 1px;
  }
  .badge-new { background: var(--charcoal); color: white; }
  .badge-sale { background: var(--champagne); color: var(--charcoal); }
  .badge-loved { background: rgba(192,192,192,0.9); color: var(--charcoal); }

  .product-actions {
    position: absolute;
    bottom: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    gap: 8px;
    transform: translateY(20px);
    opacity: 0;
    transition: var(--transition);
    z-index: 3;
  }
  .product-card:hover .product-actions {
    transform: translateY(0);
    opacity: 1;
  }
  .action-btn {
    flex: 1;
    padding: 12px;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    font-family: 'Jost', sans-serif;
    font-weight: 400;
    transition: var(--transition);
  }
  .action-cart {
    background: var(--charcoal);
    color: white;
  }
  .action-cart:hover { background: var(--champagne); color: var(--charcoal); }
  .action-wish {
    background: rgba(255,255,255,0.9);
    color: var(--charcoal);
    padding: 12px 14px;
    flex: 0;
  }
  .action-wish:hover { background: var(--charcoal); color: white; }

  .product-info { padding: 0 4px; }
  .product-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 6px;
    line-height: 1.3;
    transition: color 0.3s ease;
  }
  .product-card:hover .product-name { color: var(--silver-dark); }
  .product-material {
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    font-weight: 300;
  }
  .product-pricing {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .product-price {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--charcoal);
    letter-spacing: 0.04em;
  }
  .product-original {
    font-size: 0.8rem;
    color: var(--text-light);
    text-decoration: line-through;
    font-weight: 300;
  }
  .product-stars {
    display: flex;
    gap: 3px;
    margin-top: 10px;
    align-items: center;
  }
  .star { color: var(--champagne); font-size: 0.7rem; }
  .product-reviews {
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-left: 6px;
    letter-spacing: 0.04em;
  }

  /* SPLIT FEATURE BANNER */
  .feature-banner {
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }
  .feature-visual {
    background: var(--charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px;
    position: relative;
    overflow: hidden;
  }
  .feature-visual-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(230,199,156,0.08) 0%, transparent 60%);
  }
  .feature-content {
    background: var(--ivory-dark);
    display: flex;
    align-items: center;
    padding: 80px;
  }
  .feature-inner { max-width: 460px; }
  .feature-label {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--champagne);
    margin-bottom: 24px;
  }
  .feature-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 24px;
    color: var(--charcoal);
  }
  .feature-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.85;
    margin-bottom: 40px;
    font-weight: 300;
    letter-spacing: 0.04em;
  }
  .feature-stats {
    display: flex;
    gap: 48px;
    margin-bottom: 48px;
  }
  .stat-item { }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--charcoal);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 6px;
    font-weight: 300;
  }

  /* WHY CHOOSE US */
  .why-us {
    background: var(--charcoal);
    padding: 120px 80px;
    text-align: center;
  }
  .why-us .section-title { color: var(--ivory); }
  .why-us .section-eyebrow { color: var(--champagne); }
  .why-us .section-subtitle { color: rgba(255,255,255,0.5); }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 60px;
  }
